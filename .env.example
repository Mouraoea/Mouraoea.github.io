# Copy to .env.local for local dev (never commit .env.local).
#
# --- VITE_GITHUB_DISPATCH_TOKEN setup ---
# 1. GitHub → Settings → Developer settings → Fine-grained personal access tokens
# 2. Generate new token:
#    - Resource owner: Mouraoea
#    - Repository access: Only Mouraoea.github.io
#    - Permissions: Actions → Read and write, Contents → Read-only
# 3. Paste token below for local dev.
#
# 4. For production (mouraoea.github.io), add the SAME token as a repository secret:
#    Repo → Settings → Secrets and variables → Actions → New repository secret
#    Name: VITE_GITHUB_DISPATCH_TOKEN
#
# WARNING: Vite embeds VITE_* vars in the client bundle. Anyone can read this token
# from the deployed site. Use a fine-grained PAT limited to this repo only.
# Abuse risk is mainly triggering workflow runs (rate limits / Actions minutes).

VITE_GITHUB_REPO=Mouraoea/Mouraoea.github.io
VITE_GITHUB_REF=master
VITE_GITHUB_DISPATCH_TOKEN=

# Optional: higher IdleClans API rate limits
VITE_MARKET_API_KEY=
